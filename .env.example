# Verdict public frontend environment variables
# Copy this file to .env.local for local development.
# Add these same variables in Vercel Project Settings > Environment Variables.

VITE_APP_NAME=Verdict
VITE_APP_URL=http://localhost:5173

# Supabase browser client values
# Use the public project URL and anon key only. Never expose service role keys in Vite.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Optional public storage/blob endpoint for client-safe uploads or previews.
# Keep private blob tokens/server credentials out of VITE variables.
VITE_BLOB_PUBLIC_URL=

# Optional auth provider flags for future login providers.
VITE_ENABLE_GOOGLE_AUTH=true
VITE_ENABLE_MEGA_LOGIN=false
